{
  // Point to monorepo root so hermes-test can find workspace node_modules
  "root": "../..",

  // Use the local tsconfig for path aliases
  "tsconfig": "./tsconfig.json",

  // Shims replace native/unsupported modules with hermes-test compatible versions
  "shims": {
    // react-native shim is auto-included by the CLI, but can be explicitly declared here
    "react-native": "hermes-test/shims/react-native",
    "react-redux": "hermes-test/shims/react-redux",
    "@reduxjs/toolkit/query/react": "hermes-test/shims/rtk-query",
    "@reduxjs/toolkit/query": "hermes-test/shims/rtk-query",
    "@reduxjs/toolkit": "hermes-test/shims/reduxjs-toolkit"
  }
}
