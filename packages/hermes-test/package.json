{
  "name": "hermes-test",
  "version": "0.2.4",
  "description": "26-64x faster than Jest. A test runner built for React Native and Expo. One esbuild pass, one process, zero Babel.",
  "main": "src/index.ts",
  "types": "index.d.ts",
  "typesVersions": {
    "*": {
      "store": [
        "store.d.ts"
      ]
    }
  },
  "exports": {
    ".": "./src/index.ts",
    "./store": "./src/store.ts"
  },
  "bin": {
    "hermes-test": "bin/hermes-test.js"
  },
  "scripts": {
    "build": "tsc",
    "bundle": "node bundle.mjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/marcuzgabriel/hermes-test"
  },
  "keywords": [
    "react-native",
    "expo",
    "hermes",
    "test-runner",
    "testing",
    "hooks",
    "redux",
    "rtk-query"
  ],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.4.0",
    "esbuild": "^0.25.0",
    "react": "^19.2.0",
    "react-reconciler": "^0.33.0"
  },
  "dependencies": {
    "@react-native/js-polyfills": "^0.85.3"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "optionalDependencies": {
    "@hermes-test/darwin-arm64": "0.2.4",
    "@hermes-test/darwin-x64": "0.2.4",
    "@hermes-test/linux-x64": "0.2.4"
  },
  "files": [
    "src/",
    "bin/",
    "dist/",
    "index.d.ts",
    "store.d.ts",
    "shims/"
  ]
}
